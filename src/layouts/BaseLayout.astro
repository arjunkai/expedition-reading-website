---
import "@/styles/global.css";
import SEO from "@/components/SEO.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  includeOrgSchema?: boolean;
}

const { title, description, includeOrgSchema = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FAF6EC" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <SEO title={title} description={description} includeOrgSchema={includeOrgSchema} />
    <script is:inline>
      // Killswitch: unregister any service workers left over from the old WordPress site
      // and purge their caches. Safe to leave in — no-op if no SWs are registered.
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.getRegistrations()
          .then((regs) => Promise.all(regs.map((r) => r.unregister())))
          .catch(() => {});
      }
      if (typeof caches !== "undefined") {
        caches.keys()
          .then((keys) => Promise.all(keys.map((k) => caches.delete(k))))
          .catch(() => {});
      }
    </script>
  </head>
  <body class="bg-cream text-brown">
    <a href="#main" class="skip-link">Skip to main content</a>
    <Nav />
    <main id="main"><slot /></main>
    <Footer />
  </body>
</html>
