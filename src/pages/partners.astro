---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/Button.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const partners = (await getCollection("partners")).sort((a, b) => a.data.order - b.data.order);

const types = [
  { name: "Hospitals & clinics",   description: "Labor & delivery units, pediatric practices, and community health centers that distribute bassinet books at intake or discharge." },
  { name: "Schools & districts",   description: "Title I elementary schools and district literacy coordinators who host classroom libraries and home-reading kits." },
  { name: "Community businesses",  description: "Local shops, restaurants, and offices that host donation bins or sponsor seasonal drives." },
  { name: "Aligned nonprofits",    description: "Family support, maternal health, and literacy-adjacent organizations we can cross-promote and co-serve with." },
];
---

<BaseLayout
  title="Partners"
  description="Our partner network: Book Nook Marietta, Helping Mamas, Marietta City Schools, Moxie Burger, Creating Space, and growing. See how your organization can join."
>
  <section class="px-6 pt-16 pb-12 md:pt-24 md:pb-16">
    <div class="mx-auto max-w-[1100px]">
      <div class="label-mono flex items-center gap-3 text-teal-text">
        <span aria-hidden="true" class="inline-block h-px w-10 bg-current"></span>
        <span>Partners</span>
      </div>
      <h1
        class="mt-6 font-display font-bold leading-[1.05] tracking-[-0.02em] text-brown text-[clamp(2.5rem,6vw,5rem)] max-w-[22ch]"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 25, 'wght' 700;"
      >
        The people &amp; places that <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 600;">believed first</span>.
      </h1>
      <p class="prose-body mt-8 text-lg md:text-xl text-muted-brown max-w-[60ch]">
        Every book we deliver passes through a partner's hands. These are the organizations whose early trust made the work possible,
        and whose ongoing partnership keeps it growing.
      </p>
    </div>
  </section>

  <section class="bg-paper border-y border-border-cream px-6 py-20 md:py-28">
    <div class="mx-auto max-w-[1100px]">
      <div class="label-mono text-gold-text text-center mb-12">
        Current Partners
      </div>
      <div class="grid gap-12 md:gap-16">
        {partners.map((p, i) => (
          <article class="grid md:grid-cols-[auto_1fr] gap-x-10 md:gap-x-14 items-start border-t border-border-cream pt-10">
            <div class="flex items-start gap-4">
              <span
                class="font-display italic text-gold-text text-5xl md:text-6xl leading-[0.85]"
                style="font-variation-settings: 'opsz' 144, 'SOFT' 50, 'wght' 500;"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, "0")}
              </span>
            </div>
            <div>
              <h2
                class="font-display font-bold text-2xl md:text-3xl text-brown leading-tight"
                style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 700;"
              >
                {p.data.name}
              </h2>
              <p class="prose-body mt-4 text-base md:text-lg text-muted-brown max-w-[62ch]">
                {p.data.blurb}
              </p>
              {(p.data.website || p.data.instagram || p.data.facebook || p.data.story) && (
                <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2">
                  {p.data.website && (
                    <a href={p.data.website} rel="noopener noreferrer" target="_blank"
                       class="label-mono text-brown hover:text-gold-text transition-colors">
                      Website →
                    </a>
                  )}
                  {p.data.instagram && (
                    <a href={p.data.instagram} rel="noopener noreferrer" target="_blank"
                       class="label-mono text-brown hover:text-gold-text transition-colors">
                      Instagram →
                    </a>
                  )}
                  {p.data.facebook && (
                    <a href={p.data.facebook} rel="noopener noreferrer" target="_blank"
                       class="label-mono text-brown hover:text-gold-text transition-colors">
                      Facebook →
                    </a>
                  )}
                  {p.data.story && (
                    <a href={p.data.story} rel="noopener noreferrer" target="_blank"
                       class="label-mono text-brown hover:text-gold-text transition-colors">
                      Read their story →
                    </a>
                  )}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 py-20 md:py-28">
    <div class="mx-auto max-w-[1100px]">
      <SectionHeader
        eyebrow="Become a Partner"
        eyebrowColor="gold"
        title="Four kinds of partnership we're actively building."
        align="center"
      />
      <div class="mt-16 grid gap-x-10 gap-y-12 md:grid-cols-2">
        {types.map((t, i) => (
          <div class="border-t border-border-cream pt-6">
            <div class="flex items-baseline gap-3">
              <span
                class="font-display italic text-teal-text text-xl md:text-2xl leading-none"
                style="font-variation-settings: 'opsz' 144, 'SOFT' 50, 'wght' 500;"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, "0")}
              </span>
              <h3 class="font-display font-bold text-xl md:text-2xl text-brown">{t.name}</h3>
            </div>
            <p class="prose-body mt-4 text-base text-muted-brown">{t.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-brown text-cream px-6 py-20 md:py-28 text-center">
    <div class="mx-auto max-w-[820px]">
      <div class="label-mono text-gold mb-6">
        Start a Conversation
      </div>
      <h2
        class="font-display font-bold leading-[1.05] text-3xl md:text-4xl lg:text-5xl text-cream"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 700;"
      >
        If any of this sounds like your organization, let's talk.
      </h2>
      <p class="prose-body mt-6 text-base md:text-lg text-cream/80 max-w-[54ch] mx-auto">
        Reach out with a short note about your work and we'll follow up within a week.
      </p>
      <div class="mt-10">
        <Button variant="primary" href="/contact">Contact us →</Button>
      </div>
    </div>
  </section>
</BaseLayout>
