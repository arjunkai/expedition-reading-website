---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/Button.astro";
import StatBlock from "@/components/StatBlock.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import ProgramCard from "@/components/ProgramCard.astro";
import CtaSection from "@/components/CtaSection.astro";

const statsEntry = await getEntry("stats", "current");
if (!statsEntry) throw new Error("stats:current content missing");
const stats = statsEntry.data;

const programs = (await getCollection("programs")).sort(
  (a, b) => a.data.order - b.data.order,
);

const partnerLogos = (await getCollection("partners")).sort(
  (a, b) => a.data.order - b.data.order,
);

const gradBars = [
  { label: "Proficient 3rd-grade readers",  display: "96", sub: "%", widthPct: 96, tone: "bg-teal"      },
  { label: "Below-proficient readers",      display: "84", sub: "%", widthPct: 84, tone: "bg-gold"      },
  { label: "Below-proficient + in poverty", display: "74", sub: "%", widthPct: 74, tone: "bg-[#B8763A]" },
];
---

<BaseLayout
  title="Expedition Reading"
  description="A 501(c)(3) nonprofit placing books into the hands of children from birth onward, in partnership with hospitals, schools, and community organizations."
  includeOrgSchema={true}
>
  {/* ══════════════ HERO ══════════════ */}
  <section class="relative px-6 pt-10 pb-14 md:pt-14 md:pb-20">
    <div class="mx-auto max-w-[1280px]">
      <div class="grid gap-12 md:gap-16 lg:grid-cols-[1.1fr_1fr] lg:items-center">

        <div class="animate-rise">
          <div class="label-mono flex items-center gap-3 text-gold-text">
            <span aria-hidden="true" class="inline-block h-px w-10 bg-current"></span>
            <span>A 501(c)(3) Nonprofit · Est. 2022</span>
          </div>

          <h1
            class="mt-8 font-display font-bold leading-[1.02] tracking-[-0.02em] text-brown text-[clamp(2.75rem,7vw,5.5rem)] animate-rise animate-rise-1"
            style="font-variation-settings: 'opsz' 144, 'SOFT' 25, 'wght' 700;"
          >
            Every child<br/>
            deserves a<br/>
            <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 600;">chance to learn.</span>
          </h1>

          <p class="prose-body mt-8 max-w-[54ch] text-lg md:text-xl text-muted-brown animate-rise animate-rise-2">
            We place books into the hands of children who need them most, from hospital bassinets to classrooms, from birth onward.
          </p>

          <div class="mt-10 flex flex-col sm:flex-row sm:flex-wrap gap-4 animate-rise animate-rise-3">
            <Button variant="primary" href="/get-involved#donate">Donate books &amp; funds →</Button>
            <Button variant="secondary" href="/partners">Partner with us</Button>
          </div>
        </div>

        <figure class="relative animate-rise animate-rise-2 rounded-lg bg-paper border border-border-cream ring-1 ring-brown/10 shadow-[0_24px_48px_-16px_rgba(43,29,20,0.22)] p-7 md:p-9">
          <div class="label-mono text-gold-text">
            The long arc of literacy
          </div>
          <figcaption
            class="mt-3 font-display font-bold text-brown leading-[1.12] tracking-[-0.015em] text-2xl md:text-[1.9rem]"
            style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 700;"
          >
            Reading by 3rd grade decides what comes next.
          </figcaption>
          <p class="prose-body mt-3 text-sm md:text-base text-muted-brown max-w-[44ch]">
            On-time U.S. high school graduation rate, by 3rd-grade reading level.
          </p>

          <div class="mt-8 grid gap-5 md:gap-6">
            {gradBars.map((b) => (
              <div>
                <div class="flex items-baseline justify-between gap-3">
                  <span class="label-mono text-brown">{b.label}</span>
                  <span
                    class="font-display font-bold text-brown tabular-nums text-xl md:text-2xl leading-none"
                    style="font-variation-settings: 'opsz' 144, 'SOFT' 20, 'wght' 700;"
                  >
                    {b.display}{b.sub}
                  </span>
                </div>
                <div
                  class="mt-2 relative h-3 md:h-3.5 rounded-full bg-cream border border-border-cream overflow-hidden"
                  role="img"
                  aria-label={`${b.label}: ${b.display} percent on-time graduation`}
                >
                  <div
                    class={`${b.tone} h-full rounded-full`}
                    style={`width: ${b.widthPct}%;`}
                  ></div>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 pt-5 border-t border-border-cream label-mono text-muted-brown">
            Source: Hernandez, 2011 · Annie E. Casey Foundation
          </div>
        </figure>

      </div>
    </div>
  </section>

  {/* ══════════════ IMPACT STATS ══════════════ */}
  <section class="bg-paper border-y border-border-cream">
    <div class="mx-auto max-w-[1280px] px-6 py-20 md:py-28">
      <div class="label-mono flex items-center gap-3 text-teal-text mb-14">
        <span aria-hidden="true" class="inline-block h-px w-10 bg-current"></span>
        <span>Our Impact · As of {stats.asOf.slice(0, 4)}</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-6">
        <div class="md:border-r md:border-border-cream md:pr-6">
          <StatBlock value={`${stats.booksDelivered.toLocaleString()}+`} label="Books delivered" color="gold" />
        </div>
        <div class="md:border-r md:border-border-cream md:pr-6">
          <StatBlock value={`${stats.schools}+`} label="Schools &amp; communities reached" color="teal" />
        </div>
        <div>
          <StatBlock value={`${stats.volunteerHours}+`} label="Volunteer hours" color="brown" />
        </div>
      </div>
    </div>
  </section>

  {/* ══════════════ WHAT WE DO · EDITORIAL LIST ══════════════ */}
  <section class="px-6 py-20 md:py-28">
    <div class="mx-auto max-w-[1100px]">
      <SectionHeader
        eyebrow="What We Do"
        eyebrowColor="teal"
        title="Three programs. One mission: getting books where they matter."
        align="center"
      />

      <div class="mt-20 grid gap-14">
        {programs.map((p, i) => (
          <ProgramCard
            name={p.data.name}
            summary={p.data.summary}
            accentColor={p.data.accentColor}
            ordinal={i + 1}
          />
        ))}
      </div>
    </div>
  </section>

  {/* ══════════════ PULL QUOTE / WHY ══════════════ */}
  <section class="relative bg-paper border-y border-border-cream overflow-hidden">
    <div class="relative mx-auto max-w-[1200px] px-6 py-16 md:py-20">
      <div class="label-mono text-gold-text text-center mb-10 md:mb-12">
        Why early literacy
      </div>

      <div class="grid gap-10 md:gap-10 md:grid-cols-3">
        {[
          { stat: "1 in 4", body: "children in the U.S. grow up without learning to read.", source: "NCES" },
          { stat: "90%",    body: "of brain development happens before age 5.",              source: "Harvard CDC" },
          { stat: "7\u201310\u00d7", body: "return on every dollar spent on early literacy, across lifetime outcomes.", source: "James Heckman" },
        ].map((q) => (
          <figure class="relative h-full flex flex-col text-center md:text-left md:border-l md:border-gold/30 md:pl-8">
            <span aria-hidden="true" class="md:hidden block h-px w-10 bg-gold mx-auto mb-5"></span>
            <blockquote
              class="relative font-display leading-[1.15] tracking-[-0.01em] text-brown"
              style="font-variation-settings: 'opsz' 144, 'SOFT' 60, 'wght' 500;"
            >
              <span
                class="block font-bold italic text-gold-text text-[clamp(3rem,6vw,4.5rem)] leading-[0.95]"
                style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 700;"
              >
                {q.stat}
              </span>
              <span class="block mt-4 italic text-[clamp(1.05rem,1.4vw,1.2rem)] max-w-[28ch] mx-auto md:mx-0">
                {q.body}
              </span>
            </blockquote>
            <figcaption class="mt-auto pt-6 flex items-center justify-center md:justify-start gap-3">
              <span aria-hidden="true" class="inline-block h-px w-8 bg-gold shrink-0"></span>
              <span class="label-mono text-muted-brown">Source: {q.source}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  {/* ══════════════ PARTNERS · ACKNOWLEDGMENT STYLE ══════════════ */}
  <section class="px-6 py-24 md:py-28">
    <div class="mx-auto max-w-[1200px] text-center">
      <div class="label-mono text-teal-text mb-6">
        With Gratitude
      </div>
      <h2
        class="font-display leading-[1.1] tracking-[-0.01em] text-brown text-[clamp(1.75rem,4vw,3rem)] max-w-[22ch] mx-auto"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 40, 'wght' 600;"
      >
        The people and places who <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 500;">made this real</span>.
      </h2>
      <ul class="mt-14 flex flex-wrap justify-center items-center gap-5 md:gap-6">
        {partnerLogos.map((p) => (
          <li>
            <a
              href={`/partners#${p.id}`}
              class="group relative flex h-28 w-44 md:h-36 md:w-52 items-center justify-center rounded-xl bg-white border border-border-cream p-4 md:p-5 shadow-[0_1px_3px_rgba(43,29,20,0.05)] transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:border-gold/40 hover:shadow-[0_10px_24px_-12px_rgba(43,29,20,0.18)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-cream"
              aria-label={`Read more about ${p.data.name}`}
            >
              <img
                src={p.data.logo}
                alt={p.data.name}
                loading="lazy"
                class="max-h-full max-w-full object-contain transition-transform duration-200 group-hover:scale-[1.03]"
              />
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-14">
        <a href="/partners" class="editorial-link label-mono text-brown hover:text-gold-text">
          Become a partner →
        </a>
      </div>
    </div>
  </section>

  {/* ══════════════ FINAL CTA ══════════════ */}
  <CtaSection
    eyebrow="Join Us"
    title="One book opens a lifetime."
    subtitle="5,000 books delivered, and counting. The next one waits on you."
    ctaLabel="Donate now →"
    ctaHref="/get-involved#donate"
  />
</BaseLayout>
