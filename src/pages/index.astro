---
import { Image } from "astro:assets";
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/Button.astro";
import StatBlock from "@/components/StatBlock.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import ProgramCard from "@/components/ProgramCard.astro";
import CtaSection from "@/components/CtaSection.astro";
import heroPhoto from "@/assets/images/helping-mamas-van.jpg";

const statsEntry = await getEntry("stats", "current");
if (!statsEntry) throw new Error("stats:current content missing");
const stats = statsEntry.data;

const programs = (await getCollection("programs")).sort(
  (a, b) => a.data.order - b.data.order,
);

const partners = [
  "Book Nook Marietta",
  "Helping Mamas",
  "Marietta City Schools",
  "Moxie Burger",
  "Creating Space",
];
---

<BaseLayout
  title="Expedition Reading"
  description="A 501(c)(3) nonprofit placing books into the hands of children from birth onward, in partnership with hospitals, schools, and community organizations."
  includeOrgSchema={true}
>
  {/* ══════════════ HERO ══════════════ */}
  <section class="relative px-6 pt-10 pb-14 md:pt-14 md:pb-20">
    <div class="mx-auto max-w-[1280px]">
      <div class="grid gap-12 md:gap-16 lg:grid-cols-[1.1fr_1fr] lg:items-center">

        <div class="animate-rise">
          <div class="label-mono flex items-center gap-3 text-gold-text">
            <span aria-hidden="true" class="inline-block h-px w-10 bg-current"></span>
            <span>A 501(c)(3) Nonprofit · Est. 2022</span>
          </div>

          <h1
            class="mt-8 font-display font-bold leading-[1.02] tracking-[-0.02em] text-brown text-[clamp(2.75rem,7vw,5.5rem)] animate-rise animate-rise-1"
            style="font-variation-settings: 'opsz' 144, 'SOFT' 25, 'wght' 700;"
          >
            Every child<br/>
            deserves a<br/>
            <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 600;">chance to learn.</span>
          </h1>

          <p class="prose-body mt-8 max-w-[54ch] text-lg md:text-xl text-muted-brown animate-rise animate-rise-2">
            We place books into the hands of children who need them most, from hospital bassinets to classrooms, from birth onward.
          </p>

          <div class="mt-10 flex flex-col sm:flex-row sm:flex-wrap gap-4 animate-rise animate-rise-3">
            <Button variant="primary" href="/get-involved#donate">Donate books &amp; funds →</Button>
            <Button variant="secondary" href="/partners">Partner with us</Button>
          </div>
        </div>

        <div class="relative animate-rise animate-rise-2">
          <Image
            src={heroPhoto}
            alt="Four children stand beside the Expedition Reading delivery vehicle on a sunny afternoon, each holding a book they just received"
            widths={[480, 768, 1024, 1280]}
            sizes="(min-width: 1024px) 520px, (min-width: 768px) 50vw, 100vw"
            format="webp"
            quality={82}
            loading="eager"
            class="w-full rounded-lg object-cover aspect-[5/4] object-center ring-1 ring-brown/10 shadow-[0_24px_48px_-16px_rgba(43,29,20,0.22)]"
          />
          <div class="absolute -bottom-6 -left-6 max-w-[260px] bg-cream border border-border-cream rounded-md px-5 py-4 shadow-lg hidden md:block">
            <p class="label-mono text-gold-text">On mission</p>
            <p class="prose-body text-sm mt-2 text-brown">Books in the hands of every child, from day one.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ══════════════ IMPACT STATS ══════════════ */}
  <section class="bg-paper border-y border-border-cream">
    <div class="mx-auto max-w-[1280px] px-6 py-20 md:py-28">
      <div class="label-mono flex items-center gap-3 text-teal-text mb-14">
        <span aria-hidden="true" class="inline-block h-px w-10 bg-current"></span>
        <span>Our Impact · As of {stats.asOf.slice(0, 4)}</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-6">
        <div class="md:border-r md:border-border-cream md:pr-6">
          <StatBlock value={`${stats.booksDelivered.toLocaleString()}+`} label="Books delivered" color="gold" />
        </div>
        <div class="md:border-r md:border-border-cream md:pr-6">
          <StatBlock value={`${stats.schools}+`} label="Schools &amp; communities reached" color="teal" />
        </div>
        <div>
          <StatBlock value={`${stats.volunteerHours}+`} label="Volunteer hours" color="brown" />
        </div>
      </div>
    </div>
  </section>

  {/* ══════════════ WHAT WE DO — EDITORIAL LIST ══════════════ */}
  <section class="px-6 py-20 md:py-28">
    <div class="mx-auto max-w-[1100px]">
      <SectionHeader
        eyebrow="What We Do"
        eyebrowColor="teal"
        title="Three programs. One mission: getting books where they matter."
        align="center"
      />

      <div class="mt-20 grid gap-14">
        {programs.map((p, i) => (
          <ProgramCard
            name={p.data.name}
            summary={p.data.summary}
            accentColor={p.data.accentColor}
            ordinal={i + 1}
          />
        ))}
      </div>
    </div>
  </section>

  {/* ══════════════ PULL QUOTE / WHY ══════════════ */}
  <section class="relative bg-paper border-y border-border-cream overflow-hidden">
    <div
      aria-hidden="true"
      class="hidden sm:block pointer-events-none absolute top-4 left-6 md:left-16 font-display italic text-gold/25 text-[10rem] md:text-[16rem] leading-none select-none"
      style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 500;"
    >
      &ldquo;
    </div>
    <div
      aria-hidden="true"
      class="hidden sm:block pointer-events-none absolute bottom-0 right-6 md:right-16 font-display italic text-gold/25 text-[10rem] md:text-[16rem] leading-none select-none"
      style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 500;"
    >
      &rdquo;
    </div>

    <div class="relative mx-auto max-w-[900px] px-6 py-24 md:py-32 text-center">
      <div class="label-mono text-gold-text mb-10">
        Why early literacy
      </div>
      <blockquote
        class="font-display italic leading-[1.15] tracking-[-0.01em] text-brown text-[clamp(1.75rem,4vw,3rem)]"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 500;"
      >
        1 in 4 children in the U.S. grow up without learning to read. 90% of brain development happens before age 5. Early literacy interventions return 7&ndash;10&times; their cost in lifetime outcomes.
      </blockquote>
      <div class="mt-10 flex items-center justify-center gap-3">
        <span aria-hidden="true" class="inline-block h-px w-12 bg-gold"></span>
        <span class="label-mono text-muted-brown">Sources: NCES · Harvard CDC · James Heckman</span>
        <span aria-hidden="true" class="inline-block h-px w-12 bg-gold"></span>
      </div>
    </div>
  </section>

  {/* ══════════════ PARTNERS — ACKNOWLEDGMENT STYLE ══════════════ */}
  <section class="px-6 py-20">
    <div class="mx-auto max-w-[900px] text-center">
      <div class="label-mono text-teal-text mb-8">
        Made Possible With
      </div>
      <ul
        class="prose-body text-xl md:text-2xl leading-relaxed text-brown flex flex-col sm:flex-row sm:flex-wrap sm:justify-center items-center gap-y-2 sm:gap-y-0"
        style="font-variation-settings: 'opsz' 24, 'SOFT' 60, 'wght' 400;"
      >
        {partners.map((name, i) => (
          <li class="flex items-center">
            <span class="whitespace-nowrap">{name}</span>
            {i < partners.length - 1 && <span class="text-gold mx-2 hidden sm:inline" aria-hidden="true">&middot;</span>}
          </li>
        ))}
      </ul>
      <div class="mt-10">
        <a href="/partners" class="editorial-link label-mono text-brown hover:text-gold-text">
          Become a partner →
        </a>
      </div>
    </div>
  </section>

  {/* ══════════════ FINAL CTA ══════════════ */}
  <CtaSection
    eyebrow="Join Us"
    title="One book opens a lifetime."
    subtitle="$20 puts a book in a child's hands. $100 equips a classroom shelf. Every gift is tax-deductible."
    ctaLabel="Donate now →"
    ctaHref="/get-involved#donate"
  />
</BaseLayout>
