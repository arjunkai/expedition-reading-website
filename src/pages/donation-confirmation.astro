---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/Button.astro";
import { SITE } from "@/lib/site";
import thankYouPhoto from "@/assets/images/donation-confirmation.jpg";
---

<BaseLayout
  title="Thank you"
  description="Thank you for supporting Expedition Reading. Your gift puts books into the hands of children who need them most."
>
  <section class="px-6 pt-14 pb-10 md:pt-20 md:pb-14">
    <div class="mx-auto max-w-[1100px]">
      <div class="grid gap-12 md:gap-16 lg:grid-cols-[1fr_1.05fr] lg:items-center">

        <div class="animate-rise">
          <div class="label-mono flex items-center gap-3 text-gold-text">
            <span aria-hidden="true" class="inline-block h-px w-10 bg-current"></span>
            <span>Donation received</span>
          </div>

          <h1
            class="mt-6 font-display font-bold leading-[1.05] tracking-[-0.02em] text-brown text-[clamp(2.5rem,6vw,4.5rem)] animate-rise animate-rise-1"
            style="font-variation-settings: 'opsz' 144, 'SOFT' 25, 'wght' 700;"
          >
            Thank you, <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 600;">truly</span>.
          </h1>

          <p class="prose-body mt-8 max-w-[54ch] text-lg md:text-xl text-muted-brown animate-rise animate-rise-2">
            Your gift just became a book in a child's hands. Maybe in a hospital bassinet this week, maybe on a classroom shelf by fall. Every single one moves a child closer to reading, and every single one is because of you.
          </p>

          <p class="prose-body mt-5 max-w-[54ch] text-base md:text-lg text-muted-brown animate-rise animate-rise-2">
            A receipt from PayPal is already on its way to your inbox. Expedition Reading is a 501(c)(3) nonprofit; your donation is tax-deductible to the fullest extent allowed by law.
          </p>

          <div class="mt-10 flex flex-col sm:flex-row sm:flex-wrap gap-4 animate-rise animate-rise-3">
            <Button variant="primary" href="/">Back to home</Button>
            <Button variant="secondary" href="/what-we-do">See where it goes</Button>
          </div>

          <p class="mt-10 text-sm text-muted-brown">
            Questions about your gift? Email
            <a href={`mailto:${SITE.contactEmail}`} class="editorial-link">{SITE.contactEmail}</a>.
          </p>
        </div>

        <figure class="relative animate-rise animate-rise-2">
          <Image
            src={thankYouPhoto}
            alt="An Expedition Reading moment: books reaching the children who need them"
            widths={[480, 768, 1024, 1280]}
            sizes="(min-width: 1024px) 540px, (min-width: 768px) 50vw, 100vw"
            format="webp"
            quality={82}
            loading="eager"
            class="w-full rounded-lg object-cover aspect-[5/4] object-center ring-1 ring-brown/10 shadow-[0_24px_48px_-16px_rgba(43,29,20,0.22)]"
          />
          <div class="absolute -bottom-6 -left-6 max-w-[260px] bg-cream border border-border-cream rounded-md px-5 py-4 shadow-lg hidden md:block">
            <p class="label-mono text-gold-text">On mission</p>
            <p class="prose-body text-sm mt-2 text-brown">Every gift travels. Thank you for sending yours.</p>
          </div>
        </figure>

      </div>
    </div>
  </section>

  <section class="bg-paper border-y border-border-cream px-6 py-16 md:py-20">
    <div class="mx-auto max-w-[900px] text-center">
      <div class="label-mono text-teal-text mb-6">
        Want to do more?
      </div>
      <h2
        class="font-display font-bold leading-[1.1] tracking-[-0.01em] text-brown text-[clamp(1.75rem,3.5vw,2.75rem)] max-w-[24ch] mx-auto"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 700;"
      >
        Multiply your gift.
      </h2>
      <p class="prose-body mt-6 text-base md:text-lg text-muted-brown max-w-[56ch] mx-auto">
        Tell a friend, host a book drive, or volunteer a Saturday. Books move faster when more hands carry them.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <Button variant="secondary" href="/get-involved#host">Host a drive →</Button>
        <Button variant="secondary" href="/get-involved#volunteer">Volunteer →</Button>
      </div>
    </div>
  </section>
</BaseLayout>
