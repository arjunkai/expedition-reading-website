---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/Button.astro";
import { SITE } from "@/lib/site";
---

<BaseLayout
  title="Contact"
  description="Get in touch with Expedition Reading. We respond to email within a week, often sooner."
>
  <section class="px-6 pt-16 pb-12 md:pt-24 md:pb-16">
    <div class="mx-auto max-w-[1100px]">
      <div class="label-mono flex items-center gap-3 text-teal-text">
        <span aria-hidden="true" class="inline-block h-px w-10 bg-current"></span>
        <span>Contact</span>
      </div>
      <h1
        class="mt-6 font-display font-bold leading-[1.05] tracking-[-0.02em] text-brown text-[clamp(2.5rem,6vw,5rem)] max-w-[18ch]"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 25, 'wght' 700;"
      >
        Tell us what you're <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 600;">thinking</span>.
      </h1>
      <p class="prose-body mt-8 text-lg md:text-xl text-muted-brown max-w-[60ch]">
        Whether you're interested in partnering, donating, hosting a drive, volunteering, or you just have a question,
        drop us a message below. We aim to respond within a week, usually sooner.
      </p>

    </div>
  </section>

  {/* ══════════════ CONTACT FORM ══════════════ */}
  <section class="px-6 pb-20 md:pb-28">
    <div class="mx-auto max-w-[720px]">
      <div class="bg-paper border border-border-cream rounded-lg p-8 md:p-12 shadow-[0_24px_48px_-16px_rgba(43,29,20,0.12)]">
        <div class="label-mono text-gold-text mb-4">
          Send us a message
        </div>
        <h2
          class="font-display font-bold text-2xl md:text-3xl text-brown leading-tight"
          style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 700;"
        >
          Direct to the inbox.
        </h2>

        <form
          id="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          novalidate
          class="mt-8 space-y-5"
        >
          {/* Web3Forms auth. Access key is domain-scoped and safe to commit. */}
          <input type="hidden" name="access_key" value="cd2a5c1f-8605-4780-a1e4-81e3a0d3d3a2" />
          <input type="hidden" name="subject" value="Contact form: expeditionreading.org" />
          <input type="hidden" name="from_name" value="Expedition Reading Website" />
          {/* Honeypot. Visually hidden; bots fill it, real users don't. */}
          <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;" aria-hidden="true" />

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="cf-name" class="label-mono text-brown block mb-2">
                Name <span class="text-gold-text">*</span>
              </label>
              <input
                id="cf-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class="w-full rounded-md bg-cream border border-border-cream px-4 py-3 text-brown placeholder:text-muted-brown/60 focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition"
              />
            </div>
            <div>
              <label for="cf-email" class="label-mono text-brown block mb-2">
                Email <span class="text-gold-text">*</span>
              </label>
              <input
                id="cf-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="w-full rounded-md bg-cream border border-border-cream px-4 py-3 text-brown placeholder:text-muted-brown/60 focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition"
              />
            </div>
          </div>

          <div>
            <label for="cf-organization" class="label-mono text-brown block mb-2">
              Organization <span class="text-muted-brown" style="text-transform:none;letter-spacing:0.02em;">(optional)</span>
            </label>
            <input
              id="cf-organization"
              name="organization"
              type="text"
              autocomplete="organization"
              class="w-full rounded-md bg-cream border border-border-cream px-4 py-3 text-brown placeholder:text-muted-brown/60 focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition"
            />
          </div>

          <div>
            <label for="cf-inquiry" class="label-mono text-brown block mb-2">
              Reaching out about <span class="text-gold-text">*</span>
            </label>
            <select
              id="cf-inquiry"
              name="inquiry_type"
              required
              class="w-full rounded-md bg-cream border border-border-cream px-4 py-3 text-brown focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition"
            >
              <option value="" disabled selected>Select an option…</option>
              <option value="Partnership">Partnership</option>
              <option value="Volunteering">Volunteering</option>
              <option value="Donations / book drives">Donations / book drives</option>
              <option value="Media or press">Media / press</option>
              <option value="Something else">Something else</option>
            </select>
          </div>

          <div>
            <label for="cf-message" class="label-mono text-brown block mb-2">
              Message <span class="text-gold-text">*</span>
            </label>
            <textarea
              id="cf-message"
              name="message"
              required
              rows="5"
              class="w-full rounded-md bg-cream border border-border-cream px-4 py-3 text-brown placeholder:text-muted-brown/60 focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition resize-y"
            ></textarea>
          </div>

          <div class="flex flex-wrap items-center gap-4 pt-2">
            <Button variant="primary" type="submit">Send message →</Button>
            <span id="cf-status" class="label-mono text-muted-brown" aria-live="polite" role="status"></span>
          </div>

          <p class="prose-body text-sm text-muted-brown">
            Prefer email? Write us at <a href={`mailto:${SITE.contactEmail}`} class="editorial-link">{SITE.contactEmail}</a>.
          </p>
        </form>
      </div>
    </div>
  </section>

  <section class="bg-paper border-y border-border-cream px-6 py-20 md:py-28">
    <div class="mx-auto max-w-[1100px] grid gap-12 md:gap-x-16 md:gap-y-14 md:grid-cols-3">
      <div class="min-w-0">
        <p class="label-mono text-gold-text">Email</p>
        <p
          class="mt-4 font-display font-bold text-lg sm:text-xl md:text-2xl text-brown leading-tight [overflow-wrap:anywhere]"
          style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 700;"
        >
          <a href={`mailto:${SITE.contactEmail}`} class="editorial-link">{SITE.contactEmail}</a>
        </p>
        <p class="prose-body mt-6 text-base text-muted-brown">
          General inquiries, partnership questions, donation follow-up, media requests. Everything lands in the same inbox and we triage daily.
        </p>
      </div>

      <div class="min-w-0">
        <p class="label-mono text-teal-text">Social</p>
        <p
          class="mt-4 font-display font-bold text-xl md:text-2xl text-brown leading-tight"
          style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 700;"
        >
          <a href={SITE.socials.instagram} rel="noopener noreferrer" target="_blank" class="editorial-link">@expeditionreading</a>
        </p>
        <p class="prose-body mt-6 text-base text-muted-brown">
          Photos from recent drives, partner features, and day-to-day work. DMs open.
        </p>
      </div>

      <div class="min-w-0">
        <p class="label-mono text-red-text">Mailing</p>
        <p
          class="mt-4 font-display font-bold text-xl md:text-2xl text-brown leading-tight"
          style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 700;"
        >
          Expedition Reading, Inc.<br />Marietta, GA
        </p>
        <p class="prose-body mt-6 text-base text-muted-brown">
          Full mailing address available on request for check donations.
        </p>
      </div>
    </div>
  </section>

  <section class="px-6 py-20 md:py-24">
    <div class="mx-auto max-w-[820px] text-center">
      <div class="label-mono text-gold-text mb-4">
        Response Time
      </div>
      <p
        class="font-display text-xl md:text-2xl text-brown leading-relaxed"
        style="font-variation-settings: 'opsz' 24, 'SOFT' 50, 'wght' 500;"
      >
        Most emails get a reply within two business days. If you haven't heard from us in a week, please send a follow-up.
        Sometimes the filter catches things.
      </p>
      <div class="mt-8">
        <Button variant="primary" href={`mailto:${SITE.contactEmail}`}>Email us now →</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const statusEl = document.getElementById("cf-status");

  // Pre-select the inquiry dropdown when the user arrives with ?type=...
  // (e.g. the Host-a-drive / Volunteer CTAs on /get-involved link with ?type=drives|volunteer).
  const inquiryTypeMap: Record<string, string> = {
    drives: "Donations / book drives",
    donations: "Donations / book drives",
    volunteer: "Volunteering",
    volunteering: "Volunteering",
    partnership: "Partnership",
    media: "Media or press",
    press: "Media or press",
  };
  const paramType = new URLSearchParams(window.location.search).get("type");
  if (paramType) {
    const mapped = inquiryTypeMap[paramType.toLowerCase()];
    const select = document.getElementById("cf-inquiry") as HTMLSelectElement | null;
    if (mapped && select && Array.from(select.options).some((o) => o.value === mapped)) {
      select.value = mapped;
    }
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const submitButton = form.querySelector<HTMLButtonElement>("button[type=submit]");
    if (statusEl) statusEl.textContent = "Sending…";
    if (submitButton) submitButton.disabled = true;

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });

      if (response.ok) {
        window.location.assign("/message-received/");
      } else {
        if (statusEl) statusEl.textContent = "Something went wrong. Please email us directly.";
        if (submitButton) submitButton.disabled = false;
      }
    } catch {
      if (statusEl) statusEl.textContent = "Network error. Please email us directly.";
      if (submitButton) submitButton.disabled = false;
    }
  });
</script>
