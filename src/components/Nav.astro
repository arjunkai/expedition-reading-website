---
import { SITE } from "@/lib/site";
import Button from "./Button.astro";

const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname === `${href}/`;
---

<header class="bg-cream/90 backdrop-blur-sm sticky top-0 z-40 border-b border-border-cream">
  <nav class="mx-auto flex max-w-[1280px] items-center justify-between px-6 py-5" aria-label="Primary">
    <a href="/" class="group flex items-center gap-3 no-underline">
      <span class="flex h-10 w-10 items-center justify-center rounded-md bg-gold font-display font-bold text-brown text-lg leading-none">ER</span>
      <span
        class="hidden sm:inline font-display font-semibold text-brown text-base tracking-[-0.01em] leading-none"
        style="font-variation-settings: 'opsz' 14, 'SOFT' 50;"
      >
        Expedition Reading
      </span>
    </a>
    <ul class="hidden items-center gap-8 md:flex list-none m-0 p-0">
      {SITE.nav.map((item) => (
        <li>
          <a
            href={item.href}
            class={`label-mono text-brown hover:text-gold-text transition-colors ${isActive(item.href) ? "text-gold-text" : ""}`}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <Button href="/get-involved#donate" variant="primary">Donate</Button>
  </nav>
</header>
