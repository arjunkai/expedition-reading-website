---
import { SITE } from "@/lib/site";
import Button from "./Button.astro";

const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname === `${href}/`;
---

<header class="bg-cream/90 backdrop-blur-sm sticky top-0 z-40 border-b border-border-cream">
  <nav class="mx-auto flex max-w-[1280px] items-center justify-between gap-4 px-6 py-5" aria-label="Primary">
    <a href="/" class="flex items-center gap-3 no-underline flex-shrink-0" aria-label="Expedition Reading home">
      <span class="flex h-12 w-12 items-center justify-center rounded-md bg-paper border border-border-cream shadow-sm">
        <img src="/logo.svg" alt="" width="40" height="40" class="h-10 w-10 object-contain" />
      </span>
      <span
        class="hidden sm:inline font-display font-semibold text-brown text-base tracking-[-0.01em] leading-none"
        style="font-variation-settings: 'opsz' 14, 'SOFT' 50;"
      >
        Expedition Reading
      </span>
    </a>

    <ul class="hidden items-center gap-7 lg:flex list-none m-0 p-0">
      {SITE.nav.map((item) => (
        <li>
          <a
            href={item.href}
            class={`font-mono text-xs uppercase tracking-[0.18em] font-medium text-brown hover:text-gold-text transition-colors ${isActive(item.href) ? "text-gold-text" : ""}`}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <div class="hidden sm:block">
        <Button href="/get-involved#donate" variant="primary">Donate</Button>
      </div>
      <button
        type="button"
        id="nav-toggle"
        class="lg:hidden flex h-11 w-11 items-center justify-center rounded-md border border-border-cream text-brown"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-border-cream bg-cream"
    role="dialog"
    aria-modal="false"
    aria-label="Site navigation"
  >
    <ul class="list-none m-0 p-0 px-6 py-4">
      {SITE.nav.map((item) => (
        <li class="border-b border-border-cream last:border-b-0">
          <a
            href={item.href}
            class={`block py-4 font-display text-lg text-brown ${isActive(item.href) ? "text-gold-text" : ""}`}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-5 sm:hidden">
        <Button href="/get-involved#donate" variant="primary">Donate</Button>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById("nav-toggle");
    const menu = document.getElementById("mobile-menu");
    if (!btn || !menu) return;
    btn.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(open));
      btn.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    });
    menu.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => {
        menu.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
        btn.setAttribute("aria-label", "Open menu");
      });
    });
  })();
</script>
