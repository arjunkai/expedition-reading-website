---
import { SITE } from "@/lib/site";

const year = new Date().getFullYear();
---

{/* Thin gold rule separates the footer from whatever dark section preceded it. */}
<div class="h-[2px] w-full bg-gradient-to-r from-transparent via-gold/60 to-transparent"></div>

<footer class="bg-[#1A100A] text-cream">
  <div class="mx-auto grid max-w-[1200px] gap-10 px-6 py-16 md:grid-cols-4">
    <div>
      <div class="flex items-center gap-3">
        <img src="/logo.svg" alt="" width="40" height="40" class="h-10 w-10 object-contain bg-cream rounded-md p-1" />
        <span class="font-display font-semibold tracking-[-0.01em]">{SITE.name}</span>
      </div>
      <p class="prose-body mt-5 max-w-xs text-sm leading-relaxed text-cream/75">
        A single book can open a lifetime of possibility. We exist to make that first book accessible to every child.
      </p>
    </div>

    <div>
      <p class="label-mono text-gold">Site</p>
      <ul class="mt-5 space-y-3 text-sm list-none p-0">
        {SITE.nav.map((item) => (
          <li><a href={item.href} class="no-underline text-cream/85 hover:text-gold transition-colors">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="label-mono text-gold">Legal</p>
      <ul class="mt-5 space-y-3 text-sm list-none p-0">
        <li><a href="/privacy" class="no-underline text-cream/85 hover:text-gold transition-colors">Privacy Policy</a></li>
        <li><a href="/terms" class="no-underline text-cream/85 hover:text-gold transition-colors">Terms &amp; Conditions</a></li>
        <li><a href="/disclaimer" class="no-underline text-cream/85 hover:text-gold transition-colors">Disclaimer</a></li>
      </ul>
    </div>

    <div>
      <p class="label-mono text-gold">Contact</p>
      <ul class="mt-5 space-y-3 text-sm list-none p-0">
        <li><a href="/contact" class="no-underline text-cream/85 hover:text-gold transition-colors">Send a message</a></li>
        <li><a href={`mailto:${SITE.contactEmail}`} class="no-underline text-cream/85 hover:text-gold transition-colors break-all">{SITE.contactEmail}</a></li>
        <li><a href={SITE.socials.instagram} class="no-underline text-cream/85 hover:text-gold transition-colors" rel="noopener noreferrer" target="_blank">Instagram</a></li>
      </ul>
    </div>
  </div>

  {/* Subtle internal divider, then an even-darker base strip for the copyright. */}
  <div class="border-t border-cream/15"></div>
  <div class="bg-[#0F0905] px-6 py-7 text-center text-xs text-cream/60">
    <p>&copy; 2022&ndash;{year} {SITE.name}, Inc. &nbsp;&middot;&nbsp; 501(c)(3) nonprofit organization.</p>
    <p class="mt-2 mx-auto max-w-3xl leading-relaxed">
      Donations are voluntary and generally non-refundable. Online donations are processed securely via PayPal and subject to PayPal's terms.
      Use of this website constitutes acceptance of our Terms &amp; Conditions and Privacy Policy.
    </p>
  </div>
</footer>
