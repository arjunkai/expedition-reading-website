---
import { SITE } from "@/lib/site";

const year = new Date().getFullYear();
---

{/* Thin gold rule separates the footer from whatever dark section preceded it. */}
<div class="h-[2px] w-full bg-gradient-to-r from-transparent via-gold/60 to-transparent"></div>

<footer class="bg-[#1A100A] text-cream">
  <div class="mx-auto grid max-w-[1200px] gap-10 px-6 py-16 md:grid-cols-4">
    <div>
      <div class="flex items-center gap-3">
        <img src="/logo.svg" alt="" width="40" height="40" class="h-10 w-10 object-contain bg-cream rounded-md p-1" />
        <span class="font-display font-semibold tracking-[-0.01em]">{SITE.name}</span>
      </div>
      <p class="prose-body mt-5 max-w-xs text-sm leading-relaxed text-cream/75">
        A single book can open a lifetime of possibility. We exist to make that first book accessible to every child.
      </p>
    </div>

    <div>
      <p class="label-mono text-gold">Site</p>
      <ul class="mt-5 space-y-3 text-sm list-none p-0">
        {SITE.nav.map((item) => (
          <li><a href={item.href} class="no-underline text-cream/85 hover:text-gold transition-colors">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="label-mono text-gold">Legal</p>
      <ul class="mt-5 space-y-3 text-sm list-none p-0">
        <li><a href="/privacy" class="no-underline text-cream/85 hover:text-gold transition-colors">Privacy Policy</a></li>
        <li><a href="/terms" class="no-underline text-cream/85 hover:text-gold transition-colors">Terms &amp; Conditions</a></li>
        <li><a href="/disclaimer" class="no-underline text-cream/85 hover:text-gold transition-colors">Disclaimer</a></li>
      </ul>
    </div>

    <div>
      <p class="label-mono text-gold">Contact</p>
      <ul class="mt-5 space-y-3 text-sm list-none p-0">
        <li><a href="/contact" class="no-underline text-cream/85 hover:text-gold transition-colors">Send us a message</a></li>
        <li><a href={`mailto:${SITE.contactEmail}`} class="no-underline text-cream/85 hover:text-gold transition-colors">Email us</a></li>
      </ul>
      <div class="mt-5 flex items-center gap-3">
        <a
          href={SITE.socials.instagram}
          aria-label="Follow us on Instagram"
          rel="noopener noreferrer"
          target="_blank"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-cream/20 text-cream/85 hover:text-gold hover:border-gold/60 transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-4 w-4">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" />
          </svg>
        </a>
        <a
          href={SITE.socials.facebook}
          aria-label="Follow us on Facebook"
          rel="noopener noreferrer"
          target="_blank"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-cream/20 text-cream/85 hover:text-gold hover:border-gold/60 transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-4 w-4">
            <path d="M13.397 20.997v-8.196h2.765l.411-3.209h-3.176V7.548c0-.926.258-1.56 1.587-1.56h1.684V3.127a22.336 22.336 0 0 0-2.451-.125c-2.424 0-4.086 1.48-4.086 4.2v2.342H7.354v3.209h2.777v8.246h3.266z" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  {/* Subtle internal divider, then an even-darker base strip for the copyright. */}
  <div class="border-t border-cream/15"></div>
  <div class="bg-[#0F0905] px-6 py-7 text-center text-xs text-cream/60">
    <p>&copy; 2022&ndash;{year} {SITE.name}, Inc. &nbsp;&middot;&nbsp; 501(c)(3) nonprofit organization.</p>
    <p class="mt-2 mx-auto max-w-3xl leading-relaxed">
      Donations are voluntary and generally non-refundable. Online donations are processed securely via PayPal and subject to PayPal's terms.
      Use of this website constitutes acceptance of our Terms &amp; Conditions and Privacy Policy.
    </p>
  </div>
</footer>
