---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  eyebrowColor?: "gold" | "teal" | "brown";
  align?: "left" | "center";
}

const {
  eyebrow,
  title,
  description,
  eyebrowColor = "brown",
  align = "center",
} = Astro.props;

const EYEBROW_COLOR: Record<NonNullable<Props["eyebrowColor"]>, string> = {
  gold: "text-gold-text",
  teal: "text-teal-text",
  brown: "text-brown",
};

const alignClass = align === "center" ? "text-center mx-auto" : "";
---

<div class={`max-w-[720px] ${alignClass}`}>
  {eyebrow && (
    <div class={`label-mono flex items-center ${align === "center" ? "justify-center" : ""} gap-3 ${EYEBROW_COLOR[eyebrowColor]}`}>
      <span aria-hidden="true" class="inline-block h-px w-8 bg-current opacity-60"></span>
      <span>{eyebrow}</span>
      <span aria-hidden="true" class="inline-block h-px w-8 bg-current opacity-60"></span>
    </div>
  )}
  <h2
    class="mt-6 text-3xl md:text-4xl lg:text-5xl font-bold text-brown"
    style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 700;"
  >
    {title}
  </h2>
  {description && (
    <p class="prose-body mt-6 text-lg text-muted-brown">
      {description}
    </p>
  )}
</div>
